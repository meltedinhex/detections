// ErrTraffic "Analytics" cluster (EtherHiding -> ClickFix) - July 2026 snapshot
// Full analysis: https://meltedinhex.com/posts/clickfix-etherhiding-go-stealer/
// Microsoft Defender for Endpoint / Sentinel advanced hunting. Author: Melted in Hex.

// 1) ClickFix clipboard-PowerShell loader: hidden window + IWR + MOTW bypass
DeviceProcessEvents
| where FileName in~ ("powershell.exe","pwsh.exe")
| where ProcessCommandLine has "SEE_MASK_NOZONECHECKS"
    or (ProcessCommandLine has "Invoke-WebRequest" and ProcessCommandLine has_any ("\\x.exe","$env:TEMP",".pro/"))
| project Timestamp, DeviceName, AccountName, InitiatingProcessFileName, ProcessCommandLine

// 2) ComputerDefaults.exe UAC bypass in a non-interactive context
DeviceProcessEvents
| where FileName =~ "ComputerDefaults.exe"
| where InitiatingProcessFileName !in~ ("explorer.exe")
| project Timestamp, DeviceName, InitiatingProcessFileName, ProcessCommandLine, InitiatingProcessCommandLine

// 3) Telegram dead-drop fetched by a non-browser process (resolver behaviour)
DeviceNetworkEvents
| where RemoteUrl has_any ("telegram.me","t.me")
| where InitiatingProcessFileName !in~ ("chrome.exe","msedge.exe","firefox.exe","brave.exe","opera.exe","telegram.exe","telegramdesktop.exe")
| project Timestamp, DeviceName, InitiatingProcessFileName, RemoteUrl

// 4) Known July infrastructure (extend as hosts rotate on-chain)
DeviceNetworkEvents
| where RemoteUrl has_any ("ambiltogel.net","zewaplus.club","kaloed.pro","marjdl.pro","mamkor.pro","babelo.pro","maloke.pro","kaleda.pro","abrmot.pro","mekasa.pro","pokese.pro")
    or RemoteUrl has_all ("/api/","a=tds_cfg")
    or RemoteUrl endswith "/landing/windows.html"
| project Timestamp, DeviceName, InitiatingProcessFileName, RemoteUrl
